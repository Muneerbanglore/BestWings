---
// Stats.astro
---

<section class="relative min-h-[500px] flex items-center justify-center py-20 overflow-hidden bg-brand-darkNavy">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/stats_dubai_bg.png" 
      alt="Dubai Skyline Night" 
      class="w-full h-full object-cover object-center"
    />
    <!-- Dark overlay for readability -->
    <div class="absolute inset-0 bg-brand-navy/75 z-10"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-20 w-full flex items-center justify-start" id="stats-section-container">
    
    <!-- Transparent Overlay Card -->
    <div class="w-full max-w-2xl bg-white/5 border border-white/10 p-10 md:p-12 rounded-[2rem] backdrop-blur-md shadow-2xl flex flex-col gap-8 text-white">
      
      <!-- Card Header -->
      <div class="flex flex-col gap-2">
        <span class="text-xs font-extrabold tracking-widest text-slate-300 uppercase">
          Achieve Your Vision
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white leading-tight mt-1">
          Experience the Pinnacle of Success
        </h2>
      </div>

      <!-- Description -->
      <p class="text-base text-slate-300 leading-relaxed font-medium">
        Dubai isn't just a destination; it's the global stage for your ambition. We provide the structural foundation for your legacy in the world's most dynamic economy.
      </p>

      <!-- Stat counters -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 border-t border-white/10 pt-8 mt-2">
        <!-- Stat 1 -->
        <div class="flex flex-col gap-1">
          <div class="text-4xl md:text-5xl font-black text-white tracking-tight font-sans">
            10k+
          </div>
          <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">
            Companies Established
          </span>
        </div>

        <!-- Stat 2 -->
        <div class="flex flex-col gap-1">
          <div class="text-4xl md:text-5xl font-black text-white tracking-tight font-sans">
            100%
          </div>
          <span class="text-xs font-bold tracking-widest text-slate-400 uppercase">
            Ownership Solutions
          </span>
        </div>
      </div>

    </div>

  </div>
</section>
