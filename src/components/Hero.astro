---
// Hero.astro
---

<section id="home" class="relative min-h-[640px] lg:min-h-[720px]  mt-2 flex items-center justify-center py-20 overflow-hidden bg-brand-navy">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero_office_bg.png" 
      alt="Bestwings Office Background" 
      class="w-full h-full object-cover object-center"
    />
    <!-- Dark Navy Gradient Overlay to match mockups -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/95 via-brand-navy/90 to-brand-navy/80 z-10"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-20 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    
    <!-- Left Column: Hero Text Content -->
    <div class="lg:col-span-7 text-white flex flex-col gap-6" id="hero-content">
      
      <!-- Subheader with indicator line -->
      <div class="flex items-center gap-3">
        <span class="w-8 h-[2px] bg-brand-blue"></span>
        <span class="text-xs font-bold tracking-widest text-slate-300 uppercase">
          Premier Consultancy Dubai
        </span>
      </div>

      <!-- Main Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-[1.1] text-white">
        The UAE's Most <br class="hidden sm:inline" />
        <span class="text-white">Affordable Business</span> <br class="hidden sm:inline" />
        Setup
      </h1>

      <!-- Description Subtitle -->
      <div class="flex flex-col gap-3 max-w-xl">
        <p class="text-xl text-white font-bold leading-tight">
          Start Your Company at Prices the Market Can't Match!
        </p>
        <p class="text-sm text-slate-300 leading-relaxed font-medium">
          Launch your mainland or freezone enterprise with end-to-end advisor support, fast-track licensing approvals, and corporate bank account opening.
        </p>
      </div>

      <!-- Expertise badge -->
      <div class="flex items-center gap-3 bg-brand-darkNavy/50 border border-slate-700/50 rounded-lg p-4 max-w-xs mt-4 backdrop-blur-sm">
        <div class="bg-[#dbeafe] text-brand-navy p-1.5 rounded-full">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="text-sm font-bold text-white leading-tight">12+ Years</span>
          <span class="text-xs text-slate-400 leading-none">Trusted Expertise</span>
        </div>
      </div>

    </div>

    <!-- Right Column: Glassmorphic Inquiry Webform -->
    <div class="lg:col-span-5 flex justify-center lg:justify-end" id="hero-form-container">
      <div class="w-full max-w-md bg-white/10 border border-white/20 rounded-2xl p-8 backdrop-blur-xl shadow-2xl relative overflow-hidden">
        
        <!-- Header element with indicator cursor -->
        <div class="flex items-center gap-2 mb-6">
          <span class="text-brand-blue font-extrabold text-2xl leading-none">|</span>
          <h3 class="text-xl font-bold text-white tracking-wide">
            Schedule Your Expert Briefing
          </h3>
        </div>

        <!-- Form fields -->
        <form class="flex flex-col gap-5" id="briefing-form">
          <!-- Full Name -->
          <div class="flex flex-col gap-2">
            <label for="fullname" class="text-[10px] font-bold tracking-widest text-slate-300 uppercase">
              Full Name
            </label>
            <input 
              type="text" 
              id="fullname" 
              name="fullname" 
              placeholder="E.g. Alexander Vance"
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-400 text-sm focus:outline-none focus:border-brand-blue focus:bg-white/10 transition-all duration-200"
            />
          </div>

          <!-- Email Address -->
          <div class="flex flex-col gap-2">
            <label for="email" class="text-[10px] font-bold tracking-widest text-slate-300 uppercase">
              Email Address
            </label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              placeholder="alexander@firm.com"
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-slate-400 text-sm focus:outline-none focus:border-brand-blue focus:bg-white/10 transition-all duration-200"
            />
          </div>

          <!-- Business Structure -->
          <div class="flex flex-col gap-2">
            <label for="structure" class="text-[10px] font-bold tracking-widest text-slate-300 uppercase">
              Business Structure
            </label>
            <div class="relative">
              <select 
                id="structure" 
                name="structure" 
                class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white text-sm focus:outline-none focus:border-brand-blue focus:bg-[#09122c]/95 appearance-none cursor-pointer transition-all duration-200"
              >
                <option value="mainland" class="bg-brand-navy text-white">Mainland Company Setup</option>
                <option value="freezone" class="bg-brand-navy text-white">Freezone Authority Setup</option>
                <option value="offshore" class="bg-brand-navy text-white">Offshore Establishment</option>
              </select>
              <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-slate-300">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full bg-brand-lightBlue text-brand-navy hover:bg-white active:scale-[0.98] font-bold tracking-widest text-xs py-4 px-6 rounded-lg flex items-center justify-center gap-2 mt-2 transition-all duration-200 uppercase"
            id="btn-submit-inquiry"
          >
            Initiate Application
            <svg class="w-4 h-4 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>
        </form>

        <!-- Form Success State (hidden initially) -->
        <div id="form-success-message" class="hidden absolute inset-0 bg-brand-navy/95 flex flex-col items-center justify-center text-center p-8 z-30">
          <div class="bg-green-500/20 border border-green-500/30 text-green-400 p-4 rounded-full mb-4">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-white mb-2">Application Initiated!</h4>
          <p class="text-sm text-slate-300">
            Our expert consultants will reach out to you within the next 24 hours to schedule your briefing.
          </p>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  // Web3Forms submit handling
  const form = document.getElementById('briefing-form');
  const successMsg = document.getElementById('form-success-message');

  if (form && successMsg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitBtn = document.getElementById('btn-submit-inquiry');
      const prevBtnText = submitBtn ? submitBtn.innerHTML : 'Initiate Application';
      
      if (submitBtn) {
        submitBtn.innerHTML = 'Sending...';
        (submitBtn as HTMLButtonElement).disabled = true;
      }
      
      const formData = new FormData(form as HTMLFormElement);
      // Append Web3Forms access key and email configuration fields
      formData.append('access_key', 'e6e8c6ea-9316-44d1-9643-6e058efa2fc1');
      formData.append('subject', 'New Briefing Inquiry - Best Wings Dubai');
      formData.append('from_name', 'Best Wings Website');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();
        
        if (result.success) {
          successMsg.classList.remove('hidden');
        } else {
          alert('Submission failed: ' + result.message);
          if (submitBtn) {
            submitBtn.innerHTML = prevBtnText;
            (submitBtn as HTMLButtonElement).disabled = false;
          }
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred. Please try again later.');
        if (submitBtn) {
          submitBtn.innerHTML = prevBtnText;
          (submitBtn as HTMLButtonElement).disabled = false;
        }
      }
    });
  }
</script>
