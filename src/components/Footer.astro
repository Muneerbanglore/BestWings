---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-[#dbeafe]/30 text-slate-600 py-16 border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12" id="footer-container">
    
    <!-- Column 1: Brand, Description & Social Icons -->
    <div class="flex flex-col gap-5">
      <a href="/" class="flex items-center" id="footer-logo">
        <img src="/images/logo.png" alt="BESTWINGS Logo" class="h-14 w-auto object-contain rounded-xl" />
      </a>
      <p class="text-xs text-slate-500 leading-relaxed font-medium">
        A premier business consultancy firm based in Dubai, dedicated to providing seamless company registration services for the next generation of global entrepreneurs.
      </p>
      
      <!-- Outlined Share Buttons -->
      <div class="flex gap-2.5 mt-2">
        <!-- Share icon -->
        <a href="#" class="p-2.5 border border-slate-300 rounded hover:bg-slate-200/50 text-slate-500 transition-colors" aria-label="Share">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.57 2.286M8.684 13.258l4.57-2.286M21 12a3 3 0 11-6 0 3 3 0 016 0zm-12-6a3 3 0 11-6 0 3 3 0 016 0zm0 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </a>
        <!-- Mail icon -->
        <a href="mailto:contact@bestwings.ae" class="p-2.5 border border-slate-300 rounded hover:bg-slate-200/50 text-slate-500 transition-colors" aria-label="Email">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
        <!-- Phone icon -->
        <a href="tel:+971041234567" class="p-2.5 border border-slate-300 rounded hover:bg-slate-200/50 text-slate-500 transition-colors" aria-label="Phone">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Services -->
    <div class="flex flex-col gap-4">
      <h4 class="text-xs font-bold text-[#09122c] tracking-widest uppercase">Services</h4>
      <nav class="flex flex-col gap-3 text-xs font-semibold text-slate-500">
        <a href="#pricing" class="hover:text-brand-blue transition-colors duration-200">Mainland LLC</a>
        <a href="#pricing" class="hover:text-brand-blue transition-colors duration-200">Freezone Setup</a>
        <a href="#services" class="hover:text-brand-blue transition-colors duration-200">PRO Services</a>
        <a href="#services" class="hover:text-brand-blue transition-colors duration-200">Golden Visa</a>
      </nav>
    </div>

    <!-- Column 3: Resources -->
    <div class="flex flex-col gap-4">
      <h4 class="text-xs font-bold text-[#09122c] tracking-widest uppercase">Resources</h4>
      <nav class="flex flex-col gap-3 text-xs font-semibold text-slate-500">
        <a href="#" class="hover:text-brand-blue transition-colors duration-200">Pricing Guide</a>
        <a href="#" class="hover:text-brand-blue transition-colors duration-200">UAE Laws</a>
        <a href="#" class="hover:text-brand-blue transition-colors duration-200">Tax Guide</a>
        <a href="#" class="hover:text-brand-blue transition-colors duration-200">Strategic Blog</a>
      </nav>
    </div>

    <!-- Column 4: Headquarters -->
    <div class="flex flex-col gap-4">
      <h4 class="text-xs font-bold text-[#09122c] tracking-widest uppercase">Headquarters</h4>
      <div class="flex flex-col gap-3.5 text-xs text-slate-500 leading-relaxed font-semibold">
        <!-- Location -->
        <div class="flex items-start gap-3">
          <svg class="w-4 h-4 text-brand-blue shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Level 42, Emirates Towers,<br />Sheikh Zayed Road, Dubai, UAE</span>
        </div>
        <!-- Phone -->
        <div class="flex items-center gap-3">
          <svg class="w-4 h-4 text-brand-blue shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>+971 (0) 4 123 4567</span>
        </div>
        <!-- Email -->
        <div class="flex items-center gap-3">
          <svg class="w-4 h-4 text-brand-blue shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>contact@bestwings.ae</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom Bar: Status Badges -->
  <div class="max-w-7xl mx-auto px-6 border-t border-slate-200 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">
      &copy; {year} BESTWINGS. All rights reserved.
    </span>

    <!-- Status pill with glowing green light -->
    <div class="inline-flex items-center gap-2 bg-[#e2f0d9]/60 border border-[#c5e0b4] px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest text-[#385723]">
      Status: Office Active
      <!-- Glowing dot -->
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-650 bg-green-500"></span>
      </span>
    </div>
  </div>
</footer>
