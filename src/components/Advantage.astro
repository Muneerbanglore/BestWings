---
// Advantage.astro
---

<section class="py-24 bg-[#050a18] text-white">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    
    <!-- Left Column: Heading and description -->
    <div class="lg:col-span-5 flex flex-col gap-6" id="advantage-content">
      <div class="flex flex-col gap-2">
        <span class="text-xs font-extrabold tracking-widest text-[#3b82f6] uppercase">
          Strategic Advantage
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white leading-tight mt-2">
          We Simplify The <br />Complexities
        </h2>
      </div>

      <p class="text-sm text-slate-350 leading-relaxed max-w-md font-medium">
        Our 'A to Z' service model removes every barrier to entry in the UAE market, handling the intricacies of government bureaucracy while you focus on growth.
      </p>

      <a 
        href="#inquiry" 
        class="bg-[#dbeafe] text-brand-navy hover:bg-white text-xs font-bold tracking-widest px-8 py-4 rounded-lg self-start uppercase transition-all duration-200"
        id="btn-expert-consultation"
      >
        Expert Consultation
      </a>
    </div>

    <!-- Right Column: 2x2 Grid of features -->
    <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6" id="advantage-grid">
      
      <!-- Card 1: Government Liaison (rounded-tr-[2.5rem]) -->
      <div class="bg-white/5 border border-white/10 p-8 rounded-tl-xl rounded-tr-[2.5rem] rounded-b-xl flex flex-col gap-5 hover:bg-white/10 transition-colors duration-300">
        <div class="text-[#3b82f6]">
          <!-- Card/ID SVG -->
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <path stroke-linecap="round" d="M7 8h10M7 12h10M7 16h5" />
          </svg>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-lg font-bold text-white">Government Liaison</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Direct channels to all major UAE ministries for accelerated permit approvals.
          </p>
        </div>
      </div>

      <!-- Card 2: Bank Assistance (rounded-bl-[2.5rem]) -->
      <div class="bg-white/5 border border-white/10 p-8 rounded-t-xl rounded-br-xl rounded-bl-[2.5rem] flex flex-col gap-5 hover:bg-white/10 transition-colors duration-300">
        <div class="text-[#3b82f6]">
          <!-- Temple/Bank SVG -->
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M3 21h18M3 10h18M3 7l9-4 9 4M6 10v11M10 10v11M14 10v11M18 10v11" />
          </svg>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-lg font-bold text-white">Bank Assistance</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            Priority processing with leading local and international banks in the region.
          </p>
        </div>
      </div>

      <!-- Card 3: Transparent Pricing (rounded-br-[2.5rem]) -->
      <div class="bg-white/5 border border-white/10 p-8 rounded-t-xl rounded-bl-xl rounded-br-[2.5rem] flex flex-col gap-5 hover:bg-white/10 transition-colors duration-300">
        <div class="text-[#3b82f6]">
          <!-- Money/Cash Card SVG -->
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="2" y="5" width="20" height="14" rx="2" />
            <line x1="2" y1="10" x2="22" y2="10" />
            <path d="M6 15h2M12 15h6" />
          </svg>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-lg font-bold text-white">Transparent Pricing</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            No hidden fees or surprise costs. Fixed-fee structures for total budget clarity.
          </p>
        </div>
      </div>

      <!-- Card 4: Dedicated Support (rounded-tr-[2.5rem] or custom) -->
      <div class="bg-white/5 border border-white/10 p-8 rounded-tl-xl rounded-tr-[2.5rem] rounded-b-xl flex flex-col gap-5 hover:bg-white/10 transition-colors duration-300">
        <div class="text-[#3b82f6]">
          <!-- Support/Agent SVG -->
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M4 15a8 8 0 0116 0v2a3 3 0 01-3 3h-2v-3h3v-2a6 6 0 00-12 0v2h3v3H7a3 3 0 01-3-3v-2z" />
          </svg>
        </div>
        <div class="flex flex-col gap-2">
          <h3 class="text-lg font-bold text-white">Dedicated Support</h3>
          <p class="text-xs text-slate-400 leading-relaxed">
            24/7 access to your personal corporate advisor throughout the process.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>
