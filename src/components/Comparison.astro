---
// Comparison.astro
---

<section id="pricing" class="py-24 bg-[#f8fafc]">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header (Grid for Title & Description side-by-side) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 items-end">
      <div class="lg:col-span-7 flex flex-col gap-2">
        <span class="text-xs font-extrabold tracking-widest text-brand-blue uppercase">
          Strategic Architecture
        </span>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#09122c] mt-2">
          Choosing Your Business Structure
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-sm text-slate-500 leading-relaxed">
          Selecting the right jurisdiction is the most critical decision in your UAE journey. Compare the primary frameworks to align with your expansion goals.
        </p>
      </div>
    </div>

    <!-- Comparison Cards Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
      
      <!-- Mainland LLC Card (Dark Navy, Rounded TL and BR) -->
      <div class="bg-brand-navy text-white p-8 md:p-10 shadow-xl rounded-tl-[3rem] rounded-br-[3rem] rounded-tr-xl rounded-bl-xl border border-white/5 flex flex-col gap-8 transition-transform duration-300 hover:-translate-y-1">
        
        <!-- Card Header -->
        <div class="flex items-center gap-4">
          <div class="bg-white/10 text-white p-3 rounded-2xl border border-white/10">
            <!-- Pillar/Temple SVG -->
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18M3 10h18M3 7l9-4 9 4M6 10v11M10 10v11M14 10v11M18 10v11" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold font-sans tracking-wide">
            Mainland (LLC)
          </h3>
        </div>

        <!-- Features list -->
        <ul class="flex flex-col gap-6">
          <!-- Item 1 -->
          <li class="flex items-start gap-4">
            <div class="bg-white/10 text-[#60a5fa] p-1 rounded-full mt-0.5 border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-white tracking-wide">Trade Scope</span>
              <p class="text-xs text-slate-300 leading-relaxed mt-1">
                Operate anywhere in the UAE & global markets without restrictions.
              </p>
            </div>
          </li>

          <!-- Item 2 -->
          <li class="flex items-start gap-4">
            <div class="bg-white/10 text-[#60a5fa] p-1 rounded-full mt-0.5 border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-white tracking-wide">Physical Office</span>
              <p class="text-xs text-slate-300 leading-relaxed mt-1">
                Mandatory physical space required (Minimum 200 sq.ft).
              </p>
            </div>
          </li>

          <!-- Item 3 -->
          <li class="flex items-start gap-4">
            <div class="bg-white/10 text-[#60a5fa] p-1 rounded-full mt-0.5 border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-white tracking-wide">Visa Allocation</span>
              <p class="text-xs text-slate-300 leading-relaxed mt-1">
                Unlimited visas based on office size; ideal for large teams.
              </p>
            </div>
          </li>

          <!-- Item 4 -->
          <li class="flex items-start gap-4">
            <div class="bg-white/10 text-[#60a5fa] p-1 rounded-full mt-0.5 border border-white/10">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-white tracking-wide">Govt. Contracts</span>
              <p class="text-xs text-slate-300 leading-relaxed mt-1">
                Fully authorized to bid for all UAE government tenders.
              </p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Freezone Authority Card (White/Grey Border, Rounded TR and BL) -->
      <div class="bg-white text-slate-900 p-8 md:p-10 shadow-xl rounded-tr-[3rem] rounded-bl-[3rem] rounded-tl-xl rounded-br-xl border border-slate-200/80 flex flex-col gap-8 transition-transform duration-300 hover:-translate-y-1">
        
        <!-- Card Header -->
        <div class="flex items-center gap-4">
          <div class="bg-brand-blue/10 text-brand-blue p-3 rounded-2xl border border-brand-blue/5">
            <!-- Office/Building SVG -->
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="2" ry="2" />
              <path d="M7 2h10M12 2v20M7 8h10M7 12h10M7 16h10" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold font-sans tracking-wide text-[#09122c]">
            Freezone Authority
          </h3>
        </div>

        <!-- Features list -->
        <ul class="flex flex-col gap-6">
          <!-- Item 1 -->
          <li class="flex items-start gap-4">
            <div class="bg-slate-100 text-brand-blue p-1 rounded-full mt-0.5 border border-slate-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-[#09122c] tracking-wide">Trade Scope</span>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Trade within the specific Freezone and internationally only.
              </p>
            </div>
          </li>

          <!-- Item 2 -->
          <li class="flex items-start gap-4">
            <div class="bg-slate-100 text-brand-blue p-1 rounded-full mt-0.5 border border-slate-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-[#09122c] tracking-wide">Physical Office</span>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Flexi-desk, virtual office, and co-working options available.
              </p>
            </div>
          </li>

          <!-- Item 3 -->
          <li class="flex items-start gap-4">
            <div class="bg-slate-100 text-brand-blue p-1 rounded-full mt-0.5 border border-slate-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-[#09122c] tracking-wide">Visa Allocation</span>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Restricted number of visas based on the selected package.
              </p>
            </div>
          </li>

          <!-- Item 4 -->
          <li class="flex items-start gap-4">
            <div class="bg-slate-100 text-brand-blue p-1 rounded-full mt-0.5 border border-slate-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-[#09122c] tracking-wide">Govt. Contracts</span>
              <p class="text-xs text-slate-500 leading-relaxed mt-1">
                Limited access; often requires a local Mainland partner.
              </p>
            </div>
          </li>
        </ul>
      </div>

    </div>

  </div>
</section>
